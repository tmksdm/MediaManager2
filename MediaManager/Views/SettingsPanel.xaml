<UserControl x:Class="MediaManager.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MediaManager.ViewModels">

    <!-- SettingsPanel сам создаёт свой ViewModel -->
    <UserControl.DataContext>
        <vm:SettingsViewModel />
    </UserControl.DataContext>

    <Border Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420" Padding="0,0,12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Название поля -->
                    <ColumnDefinition Width="200" />
                    <!-- Текстовое поле -->
                    <ColumnDefinition Width="*" />
                    <!-- Кнопка Обзор -->
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <!-- Заголовок: Основные папки -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <!-- Заголовок: Панорама / Дайджест -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <!-- Заголовок: Новости -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <!-- Заголовок: Архив -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ============================================ -->
                <!-- ГРУППА: Основные папки                       -->
                <!-- ============================================ -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                           Text="📁 Основные папки"
                           FontWeight="Bold" FontSize="14"
                           Margin="0,0,0,8" />

                <!-- Папка проектов -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Папка проектов:"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="1" Grid.Column="1"
                           Text="{Binding ProjectBaseFolder, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="1" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseProjectBaseFolderCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Файл шаблона -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Файл шаблона (.prproj):"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="2" Grid.Column="1"
                           Text="{Binding SourceTemplateFile, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="2" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseSourceTemplateFileCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Папка поиска -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Папка поиска файлов:"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="3" Grid.Column="1"
                           Text="{Binding SearchFolder, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="3" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseSearchFolderCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Доп. папка поиска -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="Доп. папка поиска:"
                           VerticalAlignment="Center" Margin="0,0,8,12" />
                <TextBox   Grid.Row="4" Grid.Column="1"
                           Text="{Binding AdditionalSearchFolder, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,12" Padding="4" />
                <Button    Grid.Row="4" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseAdditionalSearchFolderCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,12" Padding="8,4" />

                <!-- ============================================ -->
                <!-- ГРУППА: Панорама / Дайджест                  -->
                <!-- ============================================ -->
                <TextBlock Grid.Row="5" Grid.ColumnSpan="3"
                           Text="🟣 Панорама / Дайджест"
                           FontWeight="Bold" FontSize="14"
                           Foreground="#8E24AA"
                           Margin="0,0,0,8" />

                <!-- Site2 архив -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="Site2 (архив):"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="6" Grid.Column="1"
                           Text="{Binding Site2Archive, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="6" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseSite2ArchiveCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Эфир -->
                <TextBlock Grid.Row="7" Grid.Column="0"
                           Text="Эфир (вещание):"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="7" Grid.Column="1"
                           Text="{Binding EfirPanorama, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="7" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseEfirPanoramaCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Кодер Site -->
                <TextBlock Grid.Row="8" Grid.Column="0"
                           Text="Кодер Site:"
                           VerticalAlignment="Center" Margin="0,0,8,12" />
                <TextBox   Grid.Row="8" Grid.Column="1"
                           Text="{Binding CoderSite, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,12" Padding="4" />
                <Button    Grid.Row="8" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseCoderSiteCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,12" Padding="8,4" />

                <!-- ============================================ -->
                <!-- ГРУППА: Новости                              -->
                <!-- ============================================ -->
                <TextBlock Grid.Row="9" Grid.ColumnSpan="3"
                           Text="🔴 Новости"
                           FontWeight="Bold" FontSize="14"
                           Foreground="#E53935"
                           Margin="0,0,0,8" />

                <!-- Хранилище новостей -->
                <TextBlock Grid.Row="10" Grid.Column="0"
                           Text="Хранилище новостей:"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="10" Grid.Column="1"
                           Text="{Binding NewsStorage, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="10" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseNewsStorageCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Эфир 25к -->
                <TextBlock Grid.Row="11" Grid.Column="0"
                           Text="Эфир 25к:"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="11" Grid.Column="1"
                           Text="{Binding NewsEfir25, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="11" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseNewsEfir25Command}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

                <!-- Кодер 25к -->
                <TextBlock Grid.Row="12" Grid.Column="0"
                           Text="Кодер 25к:"
                           VerticalAlignment="Center" Margin="0,0,8,12" />
                <TextBox   Grid.Row="12" Grid.Column="1"
                           Text="{Binding Coder25, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,12" Padding="4" />
                <Button    Grid.Row="12" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseCoder25Command}"
                           VerticalAlignment="Center" Margin="0,0,0,12" Padding="8,4" />

                <!-- ============================================ -->
                <!-- ГРУППА: Архив                                -->
                <!-- ============================================ -->
                <TextBlock Grid.Row="13" Grid.ColumnSpan="3"
                           Text="🟢 Архив (сюжеты)"
                           FontWeight="Bold" FontSize="14"
                           Foreground="#43A047"
                           Margin="0,0,0,8" />

                <!-- Сюжеты панорамы -->
                <TextBlock Grid.Row="14" Grid.Column="0"
                           Text="Сюжеты панорамы:"
                           VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox   Grid.Row="14" Grid.Column="1"
                           Text="{Binding ArchiveStories, UpdateSourceTrigger=LostFocus}"
                           VerticalAlignment="Center" Margin="0,0,8,6" Padding="4" />
                <Button    Grid.Row="14" Grid.Column="2"
                           Content="Обзор..."
                           Command="{Binding BrowseArchiveStoriesCommand}"
                           VerticalAlignment="Center" Margin="0,0,0,6" Padding="8,4" />

            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
