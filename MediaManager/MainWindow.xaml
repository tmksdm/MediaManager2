<Window x:Class="MediaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MediaManager.Views"
        x:Name="mainWindow"
        Title="Медиа-менеджер"
        Icon="app.ico"
        MinWidth="1250" MinHeight="600"
        Width="1250" Height="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стиль кнопок навигации -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль цветных кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок копирования: НЕ скопировано (пустая с рамкой) -->
        <Style x:Key="CopyButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок копирования: скопировано (залитая) -->
        <Style x:Key="CopyButtonCopiedStyle" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Стиль кнопок title bar -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка закрытия -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E53935"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderBrush="#0D47A1" BorderThickness="1" Background="#F5F5F5">
        <DockPanel>

            <!-- === TITLE BAR === -->
            <Border DockPanel.Dock="Top" Background="#1565C0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Height="40">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="⚙ Настройки"
                                Command="{Binding ToggleSettingsCommand}"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Width="Auto" Padding="12,0" FontSize="13" Margin="0,0,8,0"/>
                        <Button Content="—" Click="MinimizeButton_Click"
                                Style="{StaticResource TitleBarButtonStyle}"/>
                        <Button Content="☐" Click="MaximizeButton_Click"
                                Style="{StaticResource TitleBarButtonStyle}" x:Name="maximizeButton"/>
                        <Button Content="✕" Click="CloseButton_Click"
                                Style="{StaticResource CloseButtonStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="📺" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Медиа-менеджер" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- === SETTINGS === -->
            <views:SettingsPanel DockPanel.Dock="Top" x:Name="settingsPanel"
                                 Visibility="{Binding DataContext.IsSettingsVisible,
                                              ElementName=mainWindow,
                                              Converter={StaticResource BoolToVis}}"/>

            <!-- === TOOLBAR: ПРОЕКТ + ДАТА + ОБНОВИТЬ === -->
            <Border DockPanel.Dock="Top" Background="White" Padding="16,10"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Правая часть: навигация по датам -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="◀" Command="{Binding NavigateBackCommand}"
                                Style="{StaticResource NavButtonStyle}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding SelectedDateText}" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="▶" Command="{Binding NavigateForwardCommand}"
                                Style="{StaticResource NavButtonStyle}" Margin="0,0,12,0"/>
                        <Button Content="Сегодня" Command="{Binding GoToTodayCommand}"
                                Style="{StaticResource ActionButtonStyle}" Background="#FF8F00"
                                Margin="0,0,8,0"/>
                        <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}"
                                Style="{StaticResource ActionButtonStyle}" Background="#1565C0"/>
                    </StackPanel>

                    <!-- Левая часть: создание проекта -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Имя проекта:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="350" Height="32" FontSize="14"
                                 VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,10,0"/>
                        <Button Content="Создать проект" Command="{Binding CreateProjectCommand}"
                                Style="{StaticResource ActionButtonStyle}" Background="#43A047"/>
                    </StackPanel>
                </DockPanel>
            </Border>


            <!-- === STATUS BAR + PROGRESS === -->
            <Border DockPanel.Dock="Bottom" Background="#E0E0E0" Padding="16,6"
                    BorderBrush="#BDBDBD" BorderThickness="0,1,0,0">
                <DockPanel>
                    <ProgressBar DockPanel.Dock="Right"
                                 Width="200" Height="16"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding CopyProgress}"
                                 Margin="12,0,0,0"
                                 Foreground="#1565C0"
                                 Visibility="{Binding IsCopying, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#616161"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- === FILE LIST === -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <Grid>
                    <!-- Пустое состояние -->
                    <Border Background="White" CornerRadius="8" Padding="24" MinHeight="200"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Файлы для выбранной даты не найдены"
                                       FontSize="16" Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                            <TextBlock Text="Попробуйте выбрать другую дату или нажмите «Обновить»"
                                       FontSize="13" Foreground="#BDBDBD" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Список папок с файлами -->
                    <ItemsControl ItemsSource="{Binding FolderGroups}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <!-- Заголовок папки -->
                                        <Border Background="#F5F5F5" CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding FolderName}" FontSize="14"
                                                       FontWeight="SemiBold" Foreground="#424242"/>
                                        </Border>

                                        <!-- Файлы -->
                                        <ItemsControl ItemsSource="{Binding Files}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="8,6">
                                                        <DockPanel>
                                                            <!-- Кнопки копирования — справа -->
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">

                                                                <!-- ПАНОРАМА -->
                                                                <StackPanel Orientation="Horizontal">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding FileType}" Value="Panorama">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <Button Content="📁 Site2" Tag="Site2 (архив)" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#7B1FA2"/>
                                                                                <Setter Property="BorderBrush" Value="#7B1FA2"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToSite2}" Value="True">
                                                                                        <Setter Property="Background" Value="#7B1FA2"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#7B1FA2"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="📡 Эфир" Tag="Эфир" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#6A1B9A"/>
                                                                                <Setter Property="BorderBrush" Value="#6A1B9A"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToEfir}" Value="True">
                                                                                        <Setter Property="Background" Value="#6A1B9A"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#6A1B9A"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="🖥 Кодер" Tag="Кодер Site" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#4A148C"/>
                                                                                <Setter Property="BorderBrush" Value="#4A148C"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToCoder}" Value="True">
                                                                                        <Setter Property="Background" Value="#4A148C"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#4A148C"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </StackPanel>

                                                                <!-- ДАЙДЖЕСТ -->
                                                                <StackPanel Orientation="Horizontal">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding FileType}" Value="Digest">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <Button Content="📁 Site2" Tag="Site2 (архив)" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#7B1FA2"/>
                                                                                <Setter Property="BorderBrush" Value="#7B1FA2"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToSite2}" Value="True">
                                                                                        <Setter Property="Background" Value="#7B1FA2"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#7B1FA2"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="📡 Эфир" Tag="Эфир" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#6A1B9A"/>
                                                                                <Setter Property="BorderBrush" Value="#6A1B9A"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToEfir}" Value="True">
                                                                                        <Setter Property="Background" Value="#6A1B9A"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#6A1B9A"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="🖥 Кодер" Tag="Кодер Site" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#4A148C"/>
                                                                                <Setter Property="BorderBrush" Value="#4A148C"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToCoder}" Value="True">
                                                                                        <Setter Property="Background" Value="#4A148C"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#4A148C"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </StackPanel>

                                                                <!-- НОВОСТИ -->
                                                                <StackPanel Orientation="Horizontal">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding FileType}" Value="News">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <Button Content="📁 Хранилище" Tag="Хранилище" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                                                <Setter Property="BorderBrush" Value="#C62828"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToStorage}" Value="True">
                                                                                        <Setter Property="Background" Value="#C62828"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#C62828"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="📡 Эфир 25к" Tag="Эфир 25к" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#B71C1C"/>
                                                                                <Setter Property="BorderBrush" Value="#B71C1C"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToEfir25}" Value="True">
                                                                                        <Setter Property="Background" Value="#B71C1C"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#B71C1C"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Content="🖥 Кодер 25к" Tag="Кодер 25к" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#880E4F"/>
                                                                                <Setter Property="BorderBrush" Value="#880E4F"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToCoder25}" Value="True">
                                                                                        <Setter Property="Background" Value="#880E4F"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#880E4F"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </StackPanel>

                                                                <!-- АРХИВ -->
                                                                <StackPanel Orientation="Horizontal">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding FileType}" Value="Archive">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <Button Content="📁 Сюжеты" Tag="Сюжеты" Click="CopyButton_Click">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
                                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCopiedToArchive}" Value="True">
                                                                                        <Setter Property="Background" Value="#2E7D32"/>
                                                                                        <Setter Property="Foreground" Value="White"/>
                                                                                        <Setter Property="BorderBrush" Value="#2E7D32"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </StackPanel>

                                                            </StackPanel>


                                                            <!-- Бейдж типа + имя файла — слева -->
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Border CornerRadius="4" Padding="8,3" Margin="0,0,10,0" MinWidth="90">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#9E9E9E"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding TypeColor}" Value="#8E24AA">
                                                                                    <Setter Property="Background" Value="#8E24AA"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding TypeColor}" Value="#E53935">
                                                                                    <Setter Property="Background" Value="#E53935"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding TypeColor}" Value="#43A047">
                                                                                    <Setter Property="Background" Value="#43A047"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding TypeLabel}" Foreground="White"
                                                                               FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                                           Foreground="#212121" VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
